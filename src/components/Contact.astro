---
// Contact.astro — professional footer/contact section
---

<footer class="contact" id="contact">
  <div class="contact-glow"></div>

  <div class="contact-wrap">
    <!-- ─── Top CTA Row ────────────────────────────── -->
    <div class="cta-row">
      <div class="cta-left">
        <span class="eyebrow">06 / Let's Connect</span>
        <h2 class="cta-title">
          Got a project<br />in mind?
        </h2>
        <p class="cta-body">
          Open to freelance, collaborations, and full-time opportunities. Let's
          make something great together.
        </p>
        <a href="mailto:nikhilnishad545@gmail.com" class="email-cta">
          <span>nikhilnishad545@gmail.com</span>
          <div class="email-arrow">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
      </div>

      <div class="cta-right">
        <!-- Identity card -->
        <div class="id-card">
          <div class="id-photo">
            <img
              src="/11a3b1023d7027897f0e5a592228a0cfac36bf60.png"
              alt="Nikhil Nishad"
            />
          </div>
          <div class="id-info">
            <strong>Nikhil Nishad</strong>
            <span>Video Editor · 22 y/o</span>
          </div>
          <div class="id-status">
            <span class="status-dot"></span>
            <span>Available</span>
          </div>
        </div>

        <!-- Social grid -->
        <div class="socials">
          <a href="#" class="social-item" aria-label="Instagram">
            <div class="s-icon">IG</div>
            <div class="s-info">
              <span class="s-platform">Instagram</span>
              <span class="s-handle">@nikhilnishad</span>
            </div>
          </a>
          <a href="#" class="social-item" aria-label="YouTube">
            <div class="s-icon">YT</div>
            <div class="s-info">
              <span class="s-platform">YouTube</span>
              <span class="s-handle">Nikhil Edits</span>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── Divider ────────────────────────────────── -->
    <div class="divider"></div>

    <!-- ─── Thank You Block ────────────────────────── -->
    <div class="thanks-block">
      <div class="thanks-text">
        <span class="thanks-main">THANK YOU</span>
        <span class="thanks-year">2026</span>
      </div>
      <div class="thanks-sub">Made with passion · No AI</div>
    </div>

    <!-- ─── Footer Bottom ──────────────────────────── -->
    <div class="footer-bar">
      <span class="copyright"
        >© Developed By <a
          href="https://nyxthar.in"
          target="_blank"
          rel="noopener noreferrer"
          class="credit-link">Nyxthar.in</a
        ></span
      >
      <a href="#start" class="back-top">
        Back to top
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M12 19V5M5 12l7-7 7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  /* ═══════════════════════════════════════════════════
     CONTACT / FOOTER
  ═══════════════════════════════════════════════════ */
  .contact {
    position: relative;
    width: 100%;
    padding: 140px 64px 48px;
    background: #0b0f10;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .contact-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    bottom: -350px;
    right: -200px;
    background: radial-gradient(
      circle,
      rgba(123, 208, 255, 0.08) 0%,
      transparent 65%
    );
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
    z-index: 0;
  }

  .contact-wrap {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  /* ── Eyebrow ─────────────────────────────────────── */
  .eyebrow {
    font-family: "Space Grotesk", sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #7bd0ff;
    display: block;
    margin-bottom: 16px;
  }

  /* ── Top CTA Row ─────────────────────────────────── */
  .cta-row {
    display: flex;
    flex-direction: row;
    gap: 80px;
    align-items: flex-start;
  }

  .cta-left {
    flex: 1 1 0%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .cta-title {
    font-family: "Anton", sans-serif;
    font-size: clamp(72px, 9vw, 110px);
    font-weight: 400;
    line-height: 1;
    color: #e0e3e5;
    letter-spacing: 0.01em;
    margin: 0 0 24px;
  }

  .cta-body {
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 20px;
    line-height: 1.65;
    color: #909097;
    max-width: 440px;
    margin: 0 0 48px;
  }

  /* Email CTA */
  .email-cta {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    padding-bottom: 20px;
    width: 100%;
    max-width: 500px;
    transition: border-color 0.3s;
    group: email;
  }

  .email-cta:hover {
    border-color: #7bd0ff;
  }

  .email-cta span {
    font-family: "Space Grotesk", sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #e0e3e5;
    transition: color 0.3s;
    flex: 1;
  }

  .email-cta:hover span {
    color: #7bd0ff;
  }

  .email-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #e0e3e5;
    flex-shrink: 0;
    transition:
      background 0.3s,
      border-color 0.3s,
      transform 0.3s,
      color 0.3s;
  }

  .email-arrow svg {
    width: 18px;
    height: 18px;
  }

  .email-cta:hover .email-arrow {
    background: #7bd0ff;
    border-color: #7bd0ff;
    color: #00354a;
    transform: translateX(6px);
  }

  /* ── Right Column ────────────────────────────────── */
  .cta-right {
    flex: 0 0 380px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ID Card */
  .id-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: #191c1e;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 16px;
  }

  .id-photo {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(123, 208, 255, 0.3);
    flex-shrink: 0;
  }

  .id-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .id-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .id-info strong {
    font-family: "Space Grotesk", sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #e0e3e5;
  }

  .id-info span {
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 13px;
    color: #909097;
  }

  .id-status {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: "Space Grotesk", sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #4ade80;
    padding: 5px 12px;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.2);
    border-radius: 999px;
    white-space: nowrap;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.6);
  }

  /* Socials */
  .socials {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .social-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: #191c1e;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    text-decoration: none;
    transition:
      background 0.2s,
      border-color 0.2s,
      transform 0.2s;
  }

  .social-item:hover {
    background: #1d2022;
    border-color: rgba(123, 208, 255, 0.25);
    transform: translateY(-3px);
  }

  .s-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Space Grotesk", sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #909097;
    flex-shrink: 0;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .social-item:hover .s-icon {
    background: rgba(123, 208, 255, 0.1);
    color: #7bd0ff;
    border-color: rgba(123, 208, 255, 0.3);
  }

  .s-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .s-platform {
    font-family: "Space Grotesk", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #c6c6cd;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .s-handle {
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 12px;
    color: #45464d;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Divider ─────────────────────────────────────── */
  .divider {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
  }

  /* ── Thanks Block ────────────────────────────────── */
  .thanks-block {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .thanks-text {
    display: flex;
    flex-direction: column;
    line-height: 0.85;
  }

  .thanks-main {
    font-family: "Anton", sans-serif;
    font-size: clamp(64px, 10vw, 140px);
    color: #e0e3e5;
    letter-spacing: 0.02em;
  }

  .thanks-year {
    font-family: "Anton", sans-serif;
    font-size: clamp(64px, 10vw, 140px);
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.15);
    letter-spacing: 0.05em;
  }

  .thanks-sub {
    font-family: "Space Grotesk", sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #45464d;
    margin-bottom: 12px; /* align with bottom of year text */
  }

  /* ── Footer Bar ──────────────────────────────────── */
  .footer-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .copyright {
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 13px;
    color: #45464d;
  }

  .credit-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .credit-link:hover {
    color: #7bd0ff;
  }

  .back-top {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: "Space Grotesk", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #45464d;
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-top svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s;
  }

  .back-top:hover {
    color: #7bd0ff;
  }

  .back-top:hover svg {
    transform: translateY(-4px);
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 1024px) {
    .contact {
      padding: 100px 40px 40px;
    }
    .cta-right {
      flex: 0 0 320px;
    }
    .cta-title {
      font-size: 60px;
    }
  }

  @media (max-width: 860px) {
    .contact {
      padding: 80px 24px 40px;
    }
    .cta-row {
      flex-direction: column;
      gap: 64px;
    }
    .cta-right {
      flex: none;
      width: 100%;
    }
    .cta-title {
      font-size: 56px;
    }
    .email-cta {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .thanks-block {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
    .footer-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .socials {
      grid-template-columns: 1fr;
    }
    .cta-title {
      font-size: 48px;
    }
  }
</style>

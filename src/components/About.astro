---
// About.astro — professional, bulletproof layout
---

<section class="about" id="about">
  <div class="glow-left"></div>

  <div class="about-wrap">
    <!-- ─── Section Label ──────────────────────────── -->
    <div class="section-label">
      <span class="label-line"></span>
      <span class="label-text">01 / About</span>
      <span class="label-line"></span>
    </div>

    <!-- ─── Main Grid ──────────────────────────────── -->
    <div class="about-grid">
      <!-- LEFT: Portrait + Name ──────────────────── -->
      <div class="about-left">
        <div class="portrait-card">
          <div class="portrait-img-wrap">
            <img
              src="/661fb8692f8e1193a22eeb76b53c536781c17763.png"
              alt="Nikhil Nishad portrait"
              class="portrait-img"
            />
          </div>
          <div class="portrait-footer">
            <div class="portrait-name-block">
              <span class="portrait-name">Nikhil Nishad</span>
              <span class="portrait-role">Video Editor</span>
            </div>
            <div class="portrait-badge">Open to Work</div>
          </div>
        </div>

        <!-- Language bars below portrait -->
        <div class="lang-block">
          <p class="block-eyebrow">Languages</p>
          <div class="lang-row">
            <div class="lang-meta">
              <span>English</span><span>95%</span>
            </div>
            <div class="lang-track">
              <div class="lang-fill" style="width:95%"></div>
            </div>
          </div>
          <div class="lang-row">
            <div class="lang-meta">
              <span>Hindi</span><span>100%</span>
            </div>
            <div class="lang-track">
              <div class="lang-fill" style="width:100%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: All Info ────────────────────────── -->
      <div class="about-right">
        <!-- About text -->
        <div class="info-block">
          <h2 class="block-title">About Me</h2>
          <p class="block-body">
            I'm a self-taught visual storyteller who started editing in 2024.
            Over the years I've dived deep into graphic design, motion,
            typography, and color — building skills that compound year after
            year.
          </p>
          <p class="block-body">
            My work sits at the intersection of fast-paced short-form and
            cinematic long-form — always 100% human, always intentional.
          </p>
        </div>

        <!-- Software Skills -->
        <div class="info-block">
          <p class="block-eyebrow">02 / Software Skills</p>
          <div class="skills-grid">
            <div class="skill-pill ps">
              <span class="skill-abbr">Ps</span>
              <span>Photoshop</span>
            </div>
            <div class="skill-pill pr">
              <span class="skill-abbr">Pr</span>
              <span>Premiere Pro</span>
            </div>
            <div class="skill-pill cc">
              <span class="skill-abbr">CC</span>
              <span>CapCut</span>
            </div>
            <div class="skill-pill lr">
              <span class="skill-abbr">Lr</span>
              <span>Lightroom</span>
            </div>
          </div>
        </div>

        <!-- Edu + Experience row -->
        <div class="two-col">
          <div class="info-block">
            <p class="block-eyebrow">03 / Education</p>
            <div class="timeline-item">
              <div class="tl-dot"></div>
              <div class="tl-body">
                <span class="tl-date">2022 — 2026</span>
                <strong class="tl-title">Srinath University</strong>
                <p class="tl-sub">Computer Science &amp; Engineering</p>
              </div>
            </div>
          </div>

          <div class="info-block">
            <p class="block-eyebrow">04 / Experience</p>
            <div class="timeline-item">
              <div class="tl-dot active"></div>
              <div class="tl-body">
                <span class="tl-date">2024 — Present</span>
                <strong class="tl-title">Video Editor</strong>
                <p class="tl-sub">Crafting Eye-catching Visual for Creators</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════
     ABOUT SECTION
  ═══════════════════════════════════════════════════ */
  .about {
    position: relative;
    width: 100%;
    padding: 140px 64px;
    background: #101415;
    overflow: hidden;
  }

  .glow-left {
    position: absolute;
    width: 500px;
    height: 500px;
    left: -200px;
    top: 50%;
    transform: translateY(-50%);
    background: radial-gradient(
      circle,
      rgba(204, 0, 60, 0.1) 0%,
      transparent 70%
    );
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
    z-index: 0;
  }

  .about-wrap {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* ── Section label ───────────────────────────────── */
  .section-label {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .label-line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
  }

  .label-text {
    font-family: "Space Grotesk", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #45464d;
    white-space: nowrap;
  }

  /* ── Grid: 2 columns ─────────────────────────────── */
  .about-grid {
    display: flex;
    flex-direction: row;
    gap: 80px;
    align-items: flex-start;
  }

  /* ── LEFT column ─────────────────────────────────── */
  .about-left {
    flex: 0 0 320px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Portrait card */
  .portrait-card {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.07);
    background: #191c1e;
    box-shadow: 0 24px 60px -12px rgba(0, 0, 0, 0.6);
  }

  .portrait-img-wrap {
    width: 100%;
    height: 360px;
    overflow: hidden;
    background: linear-gradient(
      160deg,
      rgba(123, 208, 255, 0.06) 0%,
      rgba(16, 20, 21, 0) 60%
    );
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .portrait-img {
    display: block;
    width: 90%;
    height: 100%;
    object-fit: cover;
    object-position: center 10%;
    transform: scaleX(-1);
    filter: drop-shadow(0 -8px 24px rgba(0, 0, 0, 0.5));
  }

  .portrait-footer {
    padding: 20px 20px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .portrait-name-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .portrait-name {
    font-family: "Space Grotesk", sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #e0e3e5;
  }

  .portrait-role {
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 13px;
    color: #909097;
  }

  .portrait-badge {
    font-family: "Space Grotesk", sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #4ade80;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.25);
  }

  /* Language bars */
  .lang-block {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    background: #191c1e;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  .lang-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .lang-meta {
    display: flex;
    justify-content: space-between;
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 13px;
    color: #c6c6cd;
  }

  .lang-track {
    width: 100%;
    height: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  .lang-fill {
    height: 100%;
    background: linear-gradient(90deg, #7bd0ff, #4fa8d8);
    border-radius: 2px;
  }

  /* ── RIGHT column ────────────────────────────────── */
  .about-right {
    flex: 1 1 0%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  /* Info blocks */
  .info-block {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .block-eyebrow {
    font-family: "Space Grotesk", sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #7bd0ff;
    margin: 0;
  }

  .block-title {
    font-family: "Anton", sans-serif;
    font-size: clamp(48px, 6vw, 76px);
    font-weight: 400;
    color: #e0e3e5;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .block-body {
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 19px;
    line-height: 1.7;
    color: #909097;
    margin: 0;
  }

  /* Software Skills grid */
  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .skill-pill {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 20px;
    background: #191c1e;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #c6c6cd;
    transition:
      transform 0.2s,
      background 0.2s;
  }

  .skill-pill:hover {
    transform: translateY(-3px);
    background: #1d2022;
  }

  .skill-abbr {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Space Grotesk", sans-serif;
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Brand colours */
  .ps .skill-abbr {
    background: #001e36;
    color: #31a8ff;
    border: 1px solid rgba(49, 168, 255, 0.4);
  }
  .pr .skill-abbr {
    background: #1a0050;
    color: #ea77ff;
    border: 1px solid rgba(234, 119, 255, 0.4);
  }
  .ae .skill-abbr {
    background: #1a0050;
    color: #cf96ff;
    border: 1px solid rgba(207, 150, 255, 0.4);
  }
  .lr .skill-abbr {
    background: #001e36;
    color: #7bd0ff;
    border: 1px solid rgba(123, 208, 255, 0.4);
  }

  /* Two column sub-grid */
  .two-col {
    display: flex;
    flex-direction: row;
    gap: 48px;
  }

  .two-col .info-block {
    flex: 1;
  }

  /* Timeline items */
  .timeline-item {
    display: flex;
    gap: 16px;
    position: relative;
    padding-left: 20px;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }

  .tl-dot {
    position: absolute;
    left: -5px;
    top: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #272a2c;
    border: 1.5px solid #909097;
    flex-shrink: 0;
  }

  .tl-dot.active {
    background: #7bd0ff;
    border-color: #7bd0ff;
    box-shadow: 0 0 10px rgba(123, 208, 255, 0.5);
  }

  .tl-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tl-date {
    font-family: "Space Grotesk", sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #7bd0ff;
    text-transform: uppercase;
  }

  .tl-title {
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #e0e3e5;
    display: block;
  }

  .tl-sub {
    font-family: "Hanken Grotesk", sans-serif;
    font-size: 13px;
    color: #45464d;
    margin: 0;
    line-height: 1.5;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 1024px) {
    .about {
      padding: 100px 40px;
    }
    .about-left {
      flex: 0 0 280px;
    }
    .about-grid {
      gap: 48px;
    }
  }

  @media (max-width: 860px) {
    .about {
      padding: 80px 24px;
    }
    .about-grid {
      flex-direction: column;
    }
    .about-left {
      flex: none;
      width: 100%;
      max-width: 400px;
      align-self: center;
    }
    .skills-grid {
      grid-template-columns: 1fr 1fr;
    }
    .two-col {
      gap: 32px;
    }
    .block-title {
      font-size: 40px;
    }
  }

  @media (max-width: 560px) {
    .two-col {
      flex-direction: column;
      gap: 40px;
    }
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
